{
  "name": "wabi-sabi-table-generator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite",
    "dev:server": "node --env-file=.env server/index.js",
    "build": "vite build",
    "poster:stefan": "node scripts/generate_stefan_hurlemann_poster.mjs",
    "poster:stefan:cropzoom": "node scripts/generate_stefan_hurlemann_poster_draft01_cropzoom.mjs",
    "poster:stefan:three": "node scripts/generate_stefan_hurlemann_poster_three_columns.mjs",
    "preview": "vite preview",
    "start": "node server/index.js"
  },
  "dependencies": {
    "express": "^5.2.1",
    "gsap": "^3.15.0",
    "openai": "^6.34.0",
